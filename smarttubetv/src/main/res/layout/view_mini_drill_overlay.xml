<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mini_drill_overlay"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/mini_drill_overlay_background"
    android:padding="14dp"
    android:visibility="gone"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <TextView
        android:id="@+id/mini_drill_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mini Drill"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/mini_drill_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:maxLines="3"/>

    <TextView
        android:id="@+id/mini_drill_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/mini_drill_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/mini_drill_before_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="right"
        android:orientation="horizontal">

        <Button
            android:id="@+id/mini_drill_reveal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reveal"/>

        <Button
            android:id="@+id/mini_drill_later"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="Later"/>

        <Button
            android:id="@+id/mini_drill_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="Skip"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/mini_drill_after_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="right"
        android:orientation="horizontal"
        android:visibility="gone">

        <Button
            android:id="@+id/mini_drill_easy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Easy"/>

        <Button
            android:id="@+id/mini_drill_hard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="Hard"/>

        <Button
            android:id="@+id/mini_drill_again_later"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="Again later"/>
    </LinearLayout>

    <Button
        android:id="@+id/mini_drill_annoying"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginTop="4dp"
        android:text="Annoying"/>
</LinearLayout>
