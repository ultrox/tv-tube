<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mini_drill_overlay"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/mini_drill_overlay_background"
    android:padding="14dp"
    android:visibility="gone"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <TextView
        android:id="@+id/mini_drill_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mini Drill"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/mini_drill_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:maxLines="3"/>

    <TextView
        android:id="@+id/mini_drill_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/mini_drill_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/mini_drill_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:baselineAligned="false"
        android:gravity="right|center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/mini_drill_before_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="right|center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/mini_drill_reveal"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minHeight="0dp"
                android:includeFontPadding="false"
                android:gravity="center"
                android:minWidth="56dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:background="@drawable/mini_drill_action_button"
                android:text="Reveal"
                android:textAllCaps="false"
                android:textColor="@color/mini_drill_action_text"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/mini_drill_later"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minHeight="0dp"
                android:includeFontPadding="false"
                android:gravity="center"
                android:layout_marginLeft="6dp"
                android:minWidth="52dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:background="@drawable/mini_drill_action_button"
                android:text="Later"
                android:textAllCaps="false"
                android:textColor="@color/mini_drill_action_text"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/mini_drill_skip"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minHeight="0dp"
                android:includeFontPadding="false"
                android:gravity="center"
                android:layout_marginLeft="6dp"
                android:minWidth="40dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:background="@drawable/mini_drill_action_button"
                android:text="⏭"
                android:textAllCaps="false"
                android:textColor="@color/mini_drill_action_text"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/mini_drill_after_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="right|center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/mini_drill_easy"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minHeight="0dp"
                android:includeFontPadding="false"
                android:gravity="center"
                android:minWidth="48dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:background="@drawable/mini_drill_action_button"
                android:text="Easy"
                android:textAllCaps="false"
                android:textColor="@color/mini_drill_action_text"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/mini_drill_hard"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minHeight="0dp"
                android:includeFontPadding="false"
                android:gravity="center"
                android:layout_marginLeft="6dp"
                android:minWidth="48dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:background="@drawable/mini_drill_action_button"
                android:text="Hard"
                android:textAllCaps="false"
                android:textColor="@color/mini_drill_action_text"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/mini_drill_again_later"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minHeight="0dp"
                android:includeFontPadding="false"
                android:gravity="center"
                android:layout_marginLeft="6dp"
                android:minWidth="78dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:background="@drawable/mini_drill_action_button"
                android:text="Again later"
                android:textAllCaps="false"
                android:textColor="@color/mini_drill_action_text"
                android:textSize="12sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/mini_drill_annoying"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginLeft="6dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:minHeight="0dp"
            android:minWidth="40dp"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:background="@drawable/mini_drill_action_button"
            android:text="🙄"
            android:textAllCaps="false"
            android:textColor="@color/mini_drill_action_text"
            android:textSize="14sp"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/mini_drill_timeout_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="10dp"
        android:indeterminate="false"
        android:max="1000"
        android:maxHeight="3dp"
        android:minHeight="3dp"
        android:progress="1000"
        android:progressDrawable="@drawable/mini_drill_timeout_progress"/>
</LinearLayout>
